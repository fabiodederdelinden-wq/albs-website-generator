# ALBS Website-Generator — env voorbeeld
# Kopieer naar .env.local en vul in. .env.local is gitignored.

NODE_ENV=development

# ── Vercel (klant-sites deployen) ──
# Optie A: token uit `vercel login` wordt automatisch gebruikt (geen invulling nodig)
# Optie B: expliciete token (CI/headless)
VERCEL_TOKEN=
# Leeg laten = persoonlijk Vercel-account. Vul in voor een Vercel-team:
VERCEL_TEAM_ID=
VERCEL_SCOPE=

# ── Lead-data bron (aanbevolen voor 100% complete data) ──
# Zonder key: gratis Google Maps-scraping (rating + NAP betrouwbaar, review-count/
# teksten niet altijd — Google rendert die wisselend).
# Met key: Google Places API (New) levert rating, review-aantal én reviews gegarandeerd.
# Maak een key in Google Cloud Console (Places API New aanzetten + facturatie).
GOOGLE_PLACES_API_KEY=
# Forceer een bron (optioneel): places-api | maps-scrape
# ALBS_LEADDATA_PROVIDER=

# ── Reviews-generatie ──
# Als een bedrijf écht 0 reviews heeft, vult de generator realistische voorbeeld-reviews.
# Zet op 0 om dat per run uit te zetten (of per klant bij onboarding).
# ALBS_GENERATE_REVIEWS=1

# ── AI Gateway (optioneel) ──
# Zonder key werkt de generator met fallback (random template-keuze, geen logo-vision).
# Met key: slimme template-keuze + logo-validatie via Claude.
AI_GATEWAY_API_KEY=

# ── KvK (optioneel) ──
# Standaard wordt de gratis publieke openkvk-API gebruikt; geen key nodig.

# ── Runtime paden (optioneel) ──
# ALBS_RUNS_DIR=./runs
# ALBS_LEGAL_LOG=./data/legal-log.jsonl
